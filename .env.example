# EC2 Troubleshooter – example environment configuration
# Copy to .env and fill in the values appropriate for your environment.

# ── AWS ────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# AWS_PROFILE=my-profile          # optional named profile

# ── Air-gapped VPC endpoint overrides ─────────────────────────────────────
# Set USE_VPC_ENDPOINTS=true and supply endpoint URLs when the agent EC2
# instance has no direct internet access.  Obtain the endpoint URLs from
# your VPC Interface Endpoint configuration in the AWS console.
USE_VPC_ENDPOINTS=false
# VPC_ENDPOINT_EC2=https://vpce-XXXX.ec2.us-east-1.vpce.amazonaws.com
# VPC_ENDPOINT_SSM=https://vpce-XXXX.ssm.us-east-1.vpce.amazonaws.com
# VPC_ENDPOINT_STS=https://vpce-XXXX.sts.us-east-1.vpce.amazonaws.com

# ── Prometheus / Grafana Mimir ─────────────────────────────────────────────
# The agent queries Mimir directly via its Prometheus-compatible HTTP API.
# No CloudWatch is used – all node-level and app-specific metrics come from Mimir.
#
# PROMETHEUS_URL is the base URL of the Mimir query frontend, e.g.:
#   http://mimir.internal:8080/prometheus         (direct Mimir)
#   http://grafana.internal/api/datasources/proxy/1  (via Grafana proxy)
PROMETHEUS_URL=http://mimir.internal:8080/prometheus

# Mimir multi-tenant org ID – sent as X-Scope-OrgID on every request
PROMETHEUS_ORG_ID=my-org

# Label that identifies the instance in your node_exporter series.
# node_exporter default: instance=<private_ip>:9100
PROMETHEUS_INSTANCE_LABEL=instance

# How far back to query (minutes) and step size (seconds)
PROMETHEUS_LOOKBACK_MINUTES=60
PROMETHEUS_STEP_SECONDS=60

# TLS – set to false for internal CAs, or provide a CA bundle path
# PROMETHEUS_VERIFY_SSL=true
# PROMETHEUS_CA_CERT=/etc/ssl/certs/internal-ca.crt

# Auth – choose one:
# Bearer token
# PROMETHEUS_TOKEN=your-grafana-service-account-token
# Basic auth
# PROMETHEUS_USERNAME=user
# PROMETHEUS_PASSWORD=pass

# ── SSM command timeouts ───────────────────────────────────────────────────
SSM_POLL_INTERVAL_SEC=3
SSM_MAX_WAIT_SEC=120

# ── Reporter ──────────────────────────────────────────────────────────────
# Options: log | gchat | webhook
REPORTER_TYPE=log

# GChat: provide the incoming webhook URL for your Chat space
# REPORTER_TYPE=gchat
# REPORTER_GCHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/.../messages?key=...

# Generic webhook: POST full JSON report to any HTTP endpoint
# REPORTER_TYPE=webhook
# REPORTER_WEBHOOK_URL=https://internal-incident-system.example.com/ingest
# REPORTER_WEBHOOK_HEADERS={"X-Api-Key": "your-secret-key"}

# ── Alert receiver API ─────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
# API_SECRET_TOKEN=your-bearer-token   # secure the API with a bearer token

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json       # json | console
