# EC2 Troubleshooter – configuration
# Copy to .env and fill in values for your environment.
# Rules:
#   - Comments must be on their OWN line starting with #
#   - Do NOT put inline comments after a value  (e.g.  KEY=value  # bad)
#   - Inline comments are stripped automatically, but it is cleaner to avoid them

# ── AWS ────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# AWS_PROFILE=my-named-profile

# ── Air-gapped VPC endpoint overrides ─────────────────────────────────────
# Set USE_VPC_ENDPOINTS=true and fill in the endpoint URLs when the agent EC2
# instance has no direct internet access.
USE_VPC_ENDPOINTS=false
# VPC_ENDPOINT_EC2=https://vpce-XXXX.ec2.us-east-1.vpce.amazonaws.com
# VPC_ENDPOINT_SSM=https://vpce-XXXX.ssm.us-east-1.vpce.amazonaws.com
# VPC_ENDPOINT_STS=https://vpce-XXXX.sts.us-east-1.vpce.amazonaws.com

# ── SSM ────────────────────────────────────────────────────────────────────
SSM_POLL_INTERVAL_SEC=3
SSM_MAX_WAIT_SEC=120

# ── Prometheus / Grafana Mimir (multi-tenant) ──────────────────────────────
# Shared base URL for all Mimir tenants
PROMETHEUS_URL=http://mimir.internal:8080/prometheus

# Infra metrics tenant (node_exporter: cpu/memory/disk/network)
PROMETHEUS_INFRA_ORG_ID=infra

# App metrics tenant mapping: archetype-prefix -> X-Scope-OrgID
# Prefix matching is used: "platform-mimir" matches "platform-mimir (use1)"
# Use "_default" as a catch-all for unrecognised archetypes
PROMETHEUS_APP_ORG_IDS={"platform-mimir":"mimir-app","airflow":"airflow-app","_default":"app-metrics"}

# Label that identifies the instance in node_exporter series (default: instance)
PROMETHEUS_INSTANCE_LABEL=instance

# Lookback window and query resolution
PROMETHEUS_LOOKBACK_MINUTES=60
PROMETHEUS_STEP_SECONDS=60

# TLS verification
# Set to false for internal CAs in air-gapped environments
PROMETHEUS_VERIFY_SSL=true
# Path to a custom CA bundle
# PROMETHEUS_CA_CERT=/etc/ssl/certs/internal-ca.crt

# Auth – use ONE of the following (leave others commented out)
# Bearer token (Grafana service account)
# PROMETHEUS_TOKEN=your-grafana-service-account-token
# Basic auth
# PROMETHEUS_USERNAME=user
# PROMETHEUS_PASSWORD=pass

# ── Alert queue ─────────────────────────────────────────────────────────────
ALERT_QUEUE_MAX_SIZE=1000
ALERT_QUEUE_WORKERS=4
ALERT_QUEUE_RETRY_ATTEMPTS=2

# ── Reporter ────────────────────────────────────────────────────────────────
# Allowed values: log  gchat  webhook
REPORTER_TYPE=log

# Required when REPORTER_TYPE=gchat
# REPORTER_GCHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/.../messages?key=...

# Required when REPORTER_TYPE=webhook
# REPORTER_WEBHOOK_URL=https://internal-incident.example.com/ingest
# REPORTER_WEBHOOK_HEADERS={"Authorization": "Bearer your-token"}

# ── API ─────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
# API_SECRET_TOKEN=your-bearer-token

# ── Logging ─────────────────────────────────────────────────────────────────
# Allowed values: DEBUG  INFO  WARNING  ERROR
LOG_LEVEL=INFO
# Allowed values: json  console
LOG_FORMAT=json
